{
  "name": "aalis-marketplace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @aalis-marketplace/server dev",
    "publish:plugin": "pnpm --filter @aalis-marketplace/cli exec aalis-marketplace publish",
    "keygen": "pnpm --filter @aalis-marketplace/cli exec aalis-marketplace keygen"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
