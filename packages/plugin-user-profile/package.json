{
  "name": "@aalis/plugin-user-profile",
  "version": "0.1.1",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "eval:behavior": "node evals/profile-behavior-eval.mjs"
  },
  "dependencies": {
    "@aalis/plugin-agent-api": "workspace:^",
    "@aalis/plugin-commands-api": "workspace:^",
    "@aalis/plugin-llm-api": "workspace:^",
    "@aalis/plugin-message-api": "workspace:^",
    "@aalis/plugin-tools-api": "workspace:^",
    "@aalis/util-json-repair": "workspace:^"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-memory-api": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": "^0.1.0"
  },
  "aalis": {
    "service": {
      "required": [
        "memory",
        "llm"
      ],
      "optional": [
        "user-relation",
        "tools"
      ]
    }
  }
}
