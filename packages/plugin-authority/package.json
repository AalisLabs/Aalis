{
  "name": "@aalis/plugin-authority",
  "version": "0.2.0",
  "license": "MIT",
  "description": "权限系统：能力授权、跨平台身份绑定、高危操作拦截",
  "type": "module",
  "keywords": [
    "aalis",
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@aalis/plugin-commands-api": "workspace:^",
    "@aalis/plugin-platform-api": "workspace:^",
    "@aalis/plugin-storage-api": "workspace:^",
    "@aalis/plugin-webui-api": "workspace:^"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-authority-api": "workspace:*",
    "@aalis/plugin-tools-api": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": "^0.2.0"
  },
  "aalis": {
    "service": {
      "optional": [
        "commands",
        "tools"
      ],
      "provides": [
        "authority"
      ]
    }
  }
}
