{
  "name": "@aalis/plugin-adapter-onebot",
  "version": "0.4.1",
  "license": "MIT",
  "description": "OneBot v11/v12 协议适配器（QQ 等平台接入，多连接 + 自动重连）",
  "type": "module",
  "keywords": [
    "aalis",
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@aalis/plugin-agent-api": "workspace:^",
    "@aalis/plugin-llm-api": "workspace:^",
    "@aalis/plugin-message-api": "workspace:^",
    "@aalis/plugin-process-api": "workspace:^",
    "@aalis/plugin-storage-api": "workspace:^",
    "@aalis/util-network-guard": "workspace:^",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-flow-control-api": "workspace:*",
    "@aalis/plugin-media-api": "workspace:*",
    "@aalis/plugin-memory-api": "workspace:*",
    "@aalis/plugin-message-archive-api": "workspace:*",
    "@aalis/plugin-platform-api": "workspace:*",
    "@aalis/plugin-webui-api": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": ">=0.2.0 <1.0.0"
  },
  "aalis": {
    "service": {
      "required": [
        "storage",
        "process"
      ],
      "optional": [
        "llm",
        "commands",
        "message-archive",
        "persona",
        "flow-control"
      ],
      "provides": [
        "platform"
      ]
    }
  }
}
