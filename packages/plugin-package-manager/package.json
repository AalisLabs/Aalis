{
  "name": "@aalis/plugin-package-manager",
  "version": "0.1.3",
  "license": "MIT",
  "description": "插件包管理：从 npm 安装/卸载插件到 packages/",
  "type": "module",
  "keywords": [
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@aalis/plugin-process-api": "workspace:^"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": "^0.1.0"
  },
  "aalis": {
    "service": {
      "required": [
        "process"
      ],
      "provides": [
        "package-manager"
      ]
    }
  }
}
