{
  "name": "@aalis/plugin-media",
  "version": "0.5.0",
  "license": "MIT",
  "description": "媒体处理：音视频/图片的转码与收发支撑",
  "type": "module",
  "keywords": [
    "aalis",
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@aalis/plugin-agent-api": "workspace:^",
    "@aalis/plugin-llm-api": "workspace:^",
    "@aalis/plugin-message-api": "workspace:^",
    "@aalis/plugin-process-api": "workspace:^",
    "@aalis/plugin-storage-api": "workspace:^",
    "@aalis/plugin-tools-api": "workspace:^",
    "@aalis/util-network-guard": "workspace:^"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-asr-api": "workspace:*",
    "@aalis/plugin-media-api": "workspace:*",
    "@aalis/plugin-memory-api": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": ">=0.2.0 <1.0.0"
  },
  "aalis": {
    "service": {
      "required": [
        "process",
        "storage"
      ],
      "optional": [
        "llm",
        "agent",
        "asr"
      ],
      "provides": [
        "media"
      ]
    }
  }
}
