  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AalisLabs/Aalis.git",
    "directory": "packages/plugin-gateway"
  },
  "author": "Ace Nyan <ace@acenyan.com>",
  "bugs": {
    "url": "https://github.com/AalisLabs/Aalis/issues"
  },
