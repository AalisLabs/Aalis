{
  "name": "@aalis/plugin-memory-sqlite",
  "version": "0.2.0",
  "license": "MIT",
  "description": "SQLite 消息历史存储后端（本地文件，推荐）",
  "type": "module",
  "keywords": [
    "aalis",
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@aalis/plugin-memory-api": "workspace:^",
    "@aalis/plugin-storage-api": "workspace:^",
    "better-sqlite3": "^11.8.0"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-message-api": "workspace:*",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": "^0.2.0"
  },
  "aalis": {
    "service": {
      "required": [
        "storage"
      ],
      "provides": [
        "memory"
      ]
    }
  }
}
