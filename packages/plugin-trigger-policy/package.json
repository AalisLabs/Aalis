{
  "name": "@aalis/plugin-trigger-policy",
  "version": "0.2.0",
  "license": "MIT",
  "description": "触发策略：@/名字/关键词/计数/评分 决定是否回应",
  "type": "module",
  "keywords": [
    "aalis",
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@aalis/plugin-gateway-api": "workspace:^"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-flow-control-api": "workspace:*",
    "@aalis/plugin-message-api": "workspace:*",
    "@aalis/plugin-message-archive-api": "workspace:*",
    "@aalis/plugin-persona-api": "workspace:*",
    "@aalis/plugin-webui-api": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": "^0.2.0"
  },
  "aalis": {
    "service": {
      "required": [
        "gateway"
      ],
      "optional": [
        "flow-control",
        "persona",
        "message-archive"
      ],
      "provides": [
        "trigger-policy"
      ]
    }
  }
}
