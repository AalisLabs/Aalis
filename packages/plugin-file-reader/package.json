{
  "name": "@aalis/plugin-file-reader",
  "version": "0.2.0",
  "license": "MIT",
  "description": "文件读取：解析多种格式文件供 AI 理解",
  "type": "module",
  "keywords": [
    "aalis",
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@aalis/plugin-agent-api": "workspace:^",
    "@aalis/plugin-storage-api": "workspace:^",
    "@aalis/plugin-tools-api": "workspace:^",
    "mammoth": "^1.8.0",
    "unpdf": "^0.12.1"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-memory-api": "workspace:*",
    "@aalis/plugin-message-api": "workspace:*",
    "@aalis/plugin-session-manager-api": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": "^0.2.0"
  },
  "aalis": {
    "service": {
      "required": [
        "storage"
      ],
      "optional": [
        "agent",
        "memory"
      ],
      "provides": [
        "file-reader"
      ]
    }
  }
}
