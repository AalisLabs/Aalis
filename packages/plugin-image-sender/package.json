    "@aalis/plugin-storage-api": "workspace:^",
    "@aalis/plugin-tools-api": "workspace:^"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-media-api": "workspace:*",
    "@aalis/plugin-memory-api": "workspace:*",
    "@aalis/plugin-message-archive-api": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": "^0.2.0"
  },
  "aalis": {
    "service": {
      "optional": [
        "memory",
        "media",
        "message-archive"
      ]
