{
  "name": "@aalis/plugin-webui-server",
  "version": "0.2.0",
  "license": "AGPL-3.0-only",
  "description": "Web 管理界面后端：对话/插件/服务/市场/文件",
  "type": "module",
  "keywords": [
    "aalis",
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@aalis/plugin-platform-api": "workspace:^",
    "@aalis/plugin-process-api": "workspace:^",
    "@aalis/plugin-storage-api": "workspace:^",
    "@aalis/plugin-webui-api": "workspace:^",
    "@aalis/util-network-guard": "workspace:^",
    "express": "^5.1.0",
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-agent-api": "workspace:*",
    "@aalis/plugin-authority-api": "workspace:*",
    "@aalis/plugin-commands-api": "workspace:*",
    "@aalis/plugin-doctor-api": "workspace:*",
    "@aalis/plugin-llm-api": "workspace:*",
    "@aalis/plugin-memory-api": "workspace:*",
    "@aalis/plugin-message-api": "workspace:*",
    "@aalis/plugin-package-manager": "workspace:*",
    "@aalis/plugin-persona-api": "workspace:*",
    "@aalis/plugin-session-manager-api": "workspace:*",
    "@aalis/plugin-todo-list": "workspace:*",
    "@aalis/plugin-tools-api": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": "^0.2.0"
  },
  "aalis": {
    "service": {
      "optional": [
        "storage",
        "authority",
        "commands",
        "platform",
        "process"
      ],
      "provides": [
        "webui-server"
      ]
    }
  }
}
