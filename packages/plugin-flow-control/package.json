{
  "name": "@aalis/plugin-flow-control",
  "version": "0.4.0",
  "license": "MIT",
  "description": "平台无关流控：禁言/冷却/限速/闲置触发",
  "type": "module",
  "keywords": [
    "aalis",
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@aalis/plugin-flow-control-api": "workspace:^",
    "@aalis/plugin-gateway-api": "workspace:^",
    "@aalis/plugin-message-api": "workspace:^",
    "@aalis/plugin-storage-api": "workspace:^"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-message-archive-api": "workspace:*",
    "@aalis/plugin-webui-api": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": ">=0.2.0 <1.0.0"
  },
  "aalis": {
    "service": {
      "required": [
        "gateway"
      ],
      "optional": [
        "message-archive"
      ],
      "provides": [
        "flow-control"
      ]
    }
  }
}
