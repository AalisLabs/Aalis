{
  "name": "@aalis/plugin-doctor",
  "version": "0.1.1",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@aalis/plugin-commands-api": "workspace:^",
    "@aalis/plugin-webui-api": "workspace:^"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-doctor-api": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": "^0.1.0"
  },
  "aalis": {
    "service": {
      "optional": [
        "plugins",
        "commands"
      ],
      "provides": [
        "doctor"
      ]
    }
  }
}
