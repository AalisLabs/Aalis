{
  "name": "@aalis/plugin-session-manager",
  "version": "0.2.0",
  "license": "MIT",
  "description": "会话管理：生命周期、平台配置、会话树",
  "type": "module",
  "keywords": [
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@aalis/plugin-agent-api": "workspace:^",
    "@aalis/plugin-llm-api": "workspace:^",
    "@aalis/plugin-session-manager-api": "workspace:^",
    "@aalis/plugin-webui-api": "workspace:^"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-memory-api": "workspace:*",
    "@aalis/plugin-message-api": "workspace:*",
    "@aalis/plugin-persona-api": "workspace:*",
    "@aalis/plugin-tools-api": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": "^0.2.0"
  },
  "aalis": {
    "service": {
      "required": [
        "memory"
      ],
      "optional": [
        "agent",
        "platform",
        "persona",
        "llm"
      ],
      "provides": [
        "session-manager"
      ]
    }
  }
}
