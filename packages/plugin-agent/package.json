{
  "name": "@aalis/plugin-agent",
  "version": "0.5.0",
  "license": "MIT",
  "description": "对话编排核心：消息构建、工具循环、上下文管理",
  "type": "module",
  "keywords": [
    "aalis",
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@aalis/plugin-commands-api": "workspace:^",
    "@aalis/plugin-llm-api": "workspace:^",
    "@aalis/plugin-message-api": "workspace:^",
    "@aalis/plugin-platform-api": "workspace:^",
    "@aalis/util-text-normalize": "workspace:^"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-agent-api": "workspace:*",
    "@aalis/plugin-gateway-api": "workspace:*",
    "@aalis/plugin-memory-api": "workspace:*",
    "@aalis/plugin-message-archive-api": "workspace:*",
    "@aalis/plugin-persona-api": "workspace:*",
    "@aalis/plugin-session-manager-api": "workspace:*",
    "@aalis/plugin-tools-api": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": ">=0.2.0 <1.0.0"
  },
  "aalis": {
    "service": {
      "optional": [
        "llm",
        "memory",
        "persona",
        "message-archive",
        "platform"
      ],
      "provides": [
        "agent"
      ]
    }
  }
}
