{
  "name": "@aalis/plugin-commands",
  "version": "0.1.2",
  "license": "MIT",
  "description": "斜杠指令系统：注册与分发 /command",
  "type": "module",
  "keywords": [
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@aalis/plugin-commands-api": "workspace:^",
    "@aalis/plugin-doctor-api": "workspace:^",
    "@aalis/plugin-gateway-api": "workspace:^",
    "@aalis/plugin-storage-api": "workspace:^"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-authority-api": "workspace:*",
    "@aalis/plugin-memory-api": "workspace:*",
    "@aalis/plugin-tools-api": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": "^0.1.0"
  },
  "aalis": {
    "service": {
      "required": [
        "gateway"
      ],
      "optional": [
        "doctor"
      ],
      "provides": [
        "commands"
      ]
    }
  }
}
