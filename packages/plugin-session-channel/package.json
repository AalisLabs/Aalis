{
  "name": "@aalis/plugin-session-channel",
  "version": "0.2.0",
  "license": "MIT",
  "description": "会话信道：群聊/频道级会话隔离与路由",
  "type": "module",
  "keywords": [
    "aalis-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-gateway-api": "workspace:*",
    "@aalis/plugin-memory-api": "workspace:*",
    "@aalis/plugin-message-api": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@aalis/core": "^0.2.0"
  },
  "aalis": {
    "service": {
      "required": [
        "memory"
      ],
      "provides": [
        "session-channel"
      ]
    }
  }
}
