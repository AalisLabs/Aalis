{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["src/index.ts", "test/**/*.test.ts", "vitest.config.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreDependencies": ["chalk"],
  "ignore": ["**/dist/**", "**/node_modules/**", "data/**", "workspace/**"]
}
