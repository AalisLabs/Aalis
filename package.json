{
  "name": "aalis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build && tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check:biome": "biome check .",
    "format": "biome format --write .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "pnpm -r build && pnpm run check:biome && pnpm run test",
    "ci:local": "pnpm -r build && pnpm run check:biome && pnpm run test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^22.19.15",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@aalis/core": "workspace:*",
    "chalk": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "puppeteer"
    ],
    "ignoredBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
