{
  "name": "aalis",
  "version": "0.2.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build && tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check:biome": "biome check .",
    "format": "biome format --write .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "pnpm -r build && pnpm run check:biome && pnpm run test",
    "ci:local": "pnpm -r build && pnpm run check:biome && pnpm run test",
    "preflight": "pnpm -r build && pnpm test && pnpm exec biome check . && pnpm exec knip --no-progress",
    "publish:dry": "pnpm -r build && pnpm -r publish --dry-run --no-git-checks",
    "publish:all": "pnpm -r build && pnpm -r publish --access public --no-git-checks",
    "prepare": "husky"
  },
  "devDependencies": {
    "@aalis/plugin-tools-api": "workspace:*",
    "@biomejs/biome": "2.4.15",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^2.1.9",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "knip": "^5.88.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "yaml": "^2.7.0"
  },
  "dependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/runtime": "workspace:*"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "puppeteer"
    ],
    "ignoredBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
