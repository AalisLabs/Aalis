{
  "name": "aalis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build && tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check:biome": "biome check .",
    "format": "biome format --write .",
    "lint:fix": "biome check --write .",
    "ci": "pnpm -r build && pnpm run check:biome"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^22.19.15",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aalis/core": "workspace:*",
    "@aalis/plugin-agent-default": "workspace:*",
    "@aalis/plugin-cli": "workspace:*",
    "@aalis/plugin-deepseek": "workspace:*",
    "@aalis/plugin-embedding-ollama": "workspace:*",
    "@aalis/plugin-embedding-openai": "workspace:*",
    "@aalis/plugin-memory-mongodb": "workspace:*",
    "@aalis/plugin-memory-sqlite": "workspace:*",
    "@aalis/plugin-memory-vector": "workspace:*",
    "@aalis/plugin-openai": "workspace:*",
    "@aalis/plugin-persona": "workspace:*",
    "@aalis/plugin-tools-system": "workspace:*",
    "@aalis/plugin-vectorstore-flat": "workspace:*",
    "@aalis/plugin-vectorstore-lancedb": "workspace:*",
    "@aalis/plugin-websearch-serper": "workspace:*",
    "@aalis/plugin-webui-client": "workspace:*",
    "@aalis/plugin-webui-server": "workspace:*"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "puppeteer"
    ],
    "ignoredBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
